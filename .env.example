# Gemini (official SDK)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# Copilot (direct GitHub token exchange)
GITHUB_TOKEN=ghp_xxx
COPILOT_MODEL=gpt-4o

# Optional: self-hosted OpenAI-compatible Copilot proxy
# COPILOT_API_URL=http://localhost:4141/v1
# COPILOT_API_KEY=your-copilot-proxy-token

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional remote changelog feed (JSON)
# CHANGELOG_FEED_URL=https://example.com/changelog.json

# Muse Spark Bridge (self-hosted, OpenAI-compatible, free)
# Run your own: https://github.com/KNIGHTABDO/metaai-bridge
# MUSE_SPARK_API_URL=http://localhost:8000/v1
# MUSE_SPARK_MODEL=muse-spark
